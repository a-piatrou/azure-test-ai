# Azure DevOps Personal Access Token
# Required scopes: Test Management (Read), Work Items (Read)
# Plus Work Items (Read & Write) if you want sync-back to work
AZURE_DEVOPS_PAT=

# Anthropic API key for AI review / quality scoring / semantic dedupe
# Optional — only needed for `ai-review`, `quality`, and `dedupe` commands
ANTHROPIC_API_KEY=

# Default model for review (optional override)
# ATS_REVIEW_MODEL=claude-opus-4-7

# Log level: trace | debug | info | warn | error
# LOG_LEVEL=info

# Optional: webhook receiver port (only used by `webhook` command)
# WEBHOOK_PORT=8787
# WEBHOOK_SECRET=
