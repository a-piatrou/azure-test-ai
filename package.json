{
  "name": "azure-test-sync",
  "version": "0.1.0",
  "description": "Sync Azure DevOps test cases to markdown with AI-powered review and versioning",
  "type": "module",
  "bin": {
    "ats": "./src/index.ts",
    "azure-test-sync": "./src/index.ts"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@playwright/test": "^1.49.1",
    "axios": "^1.7.9",
    "axios-retry": "^4.5.0",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^13.0.0",
    "dotenv": "^16.4.7",
    "fast-glob": "^3.3.2",
    "gray-matter": "^4.0.3",
    "ora": "^8.1.1",
    "p-limit": "^6.2.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "simple-git": "^3.27.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18.18"
  }
}
